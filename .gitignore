# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude code local settings
.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts

# 手動 CSV 備份目錄 — 內含私人財務資料，永遠不 commit
money-radar-backup-*/
